# Your school's Canvas URL — students only click "Sign in with Canvas"
VITE_CANVAS_BASE_URL=https://stridek12academy.com

# Canvas Developer Key (one-time admin setup — students never create tokens)
VITE_CANVAS_CLIENT_ID=your_developer_key_id
CANVAS_CLIENT_ID=your_developer_key_id
CANVAS_CLIENT_SECRET=your_developer_key_secret

# Redirect URI to register in Canvas Admin → Developer Keys:
#   http://localhost:5173/auth/callback   (local dev)
#   https://your-domain.com/auth/callback (production)

PORT=3001
